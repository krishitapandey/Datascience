print("\n🕷️  Scraping IMDB Top 250...")

def scrape_imdb() -> pd.DataFrame:
    url     = "https://www.imdb.com/chart/top/"
    headers = {"User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/124.0.0.0 Safari/537.36"
    )}
    try:
        resp = requests.get(url, headers=headers, timeout=15)
        resp.raise_for_status()
        soup  = BeautifulSoup(resp.content, "html.parser")
        items = soup.find_all("li", class_="ipc-metadata-list-summary-item")
        movies = []
        for item in items[:50]:
            try:
                # ── fixed title extraction ──
                title_el = item.find("h3", class_="ipc-title__text")
                raw      = title_el.text.strip() if title_el else ""
                # Strip leading "1. " rank prefix
                title = ". ".join(raw.split(". ")[1:]) if ". " in raw else raw

                # rank
                rank_str = raw.split(".")[0]
                rank     = int(rank_str) if rank_str.isdigit() else 0

                # year
                year_el = item.find("span", {"data-testid": "title-year"})
                if year_el:
                    year_text = year_el.text.strip().strip("()")
                    year = int(year_text[:4]) if year_text[:4].isdigit() else 2020
                else:
                    year = 2020

                # rating
                rating_el = item.find("span", class_="ipc-rating-star--rating")
                rating = float(rating_el.text.strip()) if rating_el else None

                movies.append({
                    "title":        title,
                    "imdb_rank":    rank,
                    "release_year": year,
                    "imdb_rating":  rating,
                    "source":       "imdb_scrape",
                })
            except Exception:
                continue

        result = pd.DataFrame(movies)
        result.to_csv("imdb_top_movies.csv", index=False)
        print(f"    Scraped {len(result)} IMDB movies → imdb_top_movies.csv")
        return result

    except Exception as exc:
        print(f"     IMDB scrape failed: {exc}")
        return pd.DataFrame()

