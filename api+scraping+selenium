app = FastAPI(
    title="🎬 Movie ML API",
    description="K-Means clustering + quality classifier for movies",
    version="2.0.0",
)

# ── Request / Response models ──────────────────────────────────────────────────
class MovieInput(BaseModel):
    budget:       float = 50_000_000
    revenue:      float = 200_000_000
    runtime:      float = 120.0
    vote_average: float = 6.5
    vote_count:   float = 5_000.0
    popularity:   float = 50.0
    release_year: float = 2023.0

class ClusterResponse(BaseModel):
    cluster:       int
    cluster_name:  str
    confidence:    float
    similar_movies: list

class QualityResponse(BaseModel):
    is_quality_movie: bool
    probability:      float
    confidence:       float

class ScrapeResponse(BaseModel):
    source:  str
    records: int
    data:    list

# ── Helpers ───────────────────────────────────────────────────────────────────
def _prep_cluster(movie: MovieInput) -> np.ndarray:
    d = movie.dict()
    d["log_budget"]  = np.log1p(d["budget"])
    d["log_revenue"] = np.log1p(d["revenue"])
    d["profit"]      = d["revenue"] - d["budget"]
    d["roi"]         = d["revenue"] / d["budget"] if d["budget"] > 0 else 1.0
    row = pd.DataFrame([d])[PIPELINES["cluster"]["features"]].fillna(0)
    return PIPELINES["cluster"]["scaler"].transform(row)

def _prep_classify(movie: MovieInput) -> np.ndarray:
    d = movie.dict()
    d["log_budget"]  = np.log1p(d["budget"])
    d["log_revenue"] = np.log1p(d["revenue"])
    d["profit"]      = d["revenue"] - d["budget"]
    d["roi"]         = d["revenue"] / d["budget"] if d["budget"] > 0 else 1.0
    row = pd.DataFrame([d])[PIPELINES["classify"]["features"]].fillna(0)
    return PIPELINES["classify"]["scaler"].transform(row)

# ── Endpoints ─────────────────────────────────────────────────────────────────
@app.get("/", tags=["Info"])
async def root():
    return {
        "status":    "🎬 Movie ML API is LIVE!",
        "endpoints": [
            "/docs",
            "/predict-cluster",
            "/predict-quality",
            "/cluster-stats",
            "/scrape-imdb",
            "/scrape-rt",
        ],
    }

@app.post("/predict-cluster", response_model=ClusterResponse, tags=["ML"])
async def predict_cluster(movie: MovieInput):
    """Predict which cluster a movie belongs to."""
    try:
        X    = _prep_cluster(movie)
        clus = int(PIPELINES["cluster"]["kmeans"].predict(X)[0])
        dist = PIPELINES["cluster"]["kmeans"].transform(X)[0]
        conf = float(1 / (1 + dist.min()))
        similar = (
            PIPELINES["data"]
            .query("cluster == @clus")["title"]
            .dropna().head(5).tolist()
        )
        return ClusterResponse(
            cluster=clus,
            cluster_name=PIPELINES["cluster"]["labels"].get(clus, "Unknown"),
            confidence=round(conf, 4),
            similar_movies=similar,
        )
    except Exception as exc:
        raise HTTPException(status_code=400, detail=str(exc))

@app.post("/predict-quality", response_model=QualityResponse, tags=["ML"])
async def predict_quality(movie: MovieInput):
    """Predict whether a movie will be high quality (vote_avg ≥ 7.0)."""
    try:
        X    = _prep_classify(movie)
        prob = PIPELINES["classify"]["model"].predict_proba(X)[0]
        pred = int(PIPELINES["classify"]["model"].predict(X)[0])
        return QualityResponse(
            is_quality_movie=bool(pred),
            probability=round(float(prob[1]), 4),
            confidence=round(float(prob.max()), 4),
        )
    except Exception as exc:
        raise HTTPException(status_code=400, detail=str(exc))

@app.get("/cluster-stats", tags=["Analytics"])
async def cluster_stats():
    """Mean feature values for each cluster."""
    stats = PIPELINES["profile"].reset_index().to_dict(orient="records")
    labels = {k: v for k, v in PIPELINES["cluster"]["labels"].items()}
    return {"cluster_labels": labels, "stats": stats}

@app.get("/scrape-imdb", tags=["Scraping"])
async def live_scrape_imdb():
    """Live-scrape IMDB Top 250 and return top 20."""
    result = scrape_imdb()
    return ScrapeResponse(
        source="imdb.com/chart/top",
        records=len(result),
        data=result.head(20).to_dict(orient="records") if not result.empty else [],
    )

@app.get("/scrape-rt", tags=["Scraping"])
async def live_scrape_rt():
    """Live-scrape Rotten Tomatoes in-theaters via Selenium."""
    result = scrape_rt_selenium()
    return ScrapeResponse(
        source="rottentomatoes.com/browse/movies_in_theaters",
        records=len(result),
        data=result.to_dict(orient="records") if not result.empty else [],
    )

