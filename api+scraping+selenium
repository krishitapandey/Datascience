# 1. SETUP & DATA LOADING
print("--- Loading and Cleaning Data ---")
KEY_COLS = ["budget", "revenue", "runtime", "vote_average", "vote_count", "popularity", "release_date", "title"]

try:
    df = pd.read_csv("movies_metadata.csv", low_memory=False)
    df = df[KEY_COLS].copy()
except FileNotFoundError:
    print("Generating synthetic data for demonstration...")
    N = 1000
    df = pd.DataFrame({
        "budget": np.random.randint(500000, 300000000, N).astype(float),
        "revenue": np.random.randint(1000000, 2000000000, N).astype(float),
        "runtime": np.random.randint(75, 210, N).astype(float),
        "vote_average": np.random.uniform(3.5, 9.0, N),
        "vote_count": np.random.randint(50, 150000, N).astype(float),
        "popularity": np.random.uniform(0.5, 200, N),
        "release_date": pd.date_range("1980-01-01", periods=N, freq="10D"),
        "title": [f"Movie_{i}" for i in range(N)],
    })

# Cleaning
for col in ["budget", "revenue", "runtime", "vote_average", "vote_count", "popularity"]:
    df[col] = pd.to_numeric(df[col], errors='coerce')
df["release_date"] = pd.to_datetime(df["release_date"], errors='coerce')
df = df.dropna(subset=["release_date"]).reset_index(drop=True)

# 2. FEATURE ENGINEERING
print("--- Engineering Features ---")
df["release_year"] = df["release_date"].dt.year.fillna(2000).astype(int)
df["profit"] = df["revenue"].fillna(0) - df["budget"].fillna(0)
df["roi"] = np.where(df["budget"] > 0, df["revenue"] / df["budget"], 1.0)
df["log_budget"] = np.log1p(df["budget"].fillna(0))
df["log_revenue"] = np.log1p(df["revenue"].fillna(0))

# 3. CLUSTERING (K-Means)
print("--- Training K-Means ---")
FEATURES = ["log_budget", "log_revenue", "runtime", "popularity", "vote_average", "vote_count", "profit", "roi", "release_year"]
X_raw = df[FEATURES].fillna(df[FEATURES].median())
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X_raw)

kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
df["cluster"] = kmeans.fit_predict(X_scaled)

LABELS = {0: "Mainstream", 1: "Prestige", 2: "Indie", 3: "Blockbuster"}

# 4. CLASSIFIER (Quality)
print("--- Training Classifier ---")
y_clf = (df["vote_average"] >= 7.0).astype(int)
classifier = RandomForestClassifier(n_estimators=100, random_state=42)
classifier.fit(X_scaled, y_clf)

# 5. FASTAPI APP
app = FastAPI(title="Movie ML API")

class MovieInput(BaseModel):
    budget: float = 50000000
    revenue: float = 150000000
    runtime: float = 120
    vote_average: float = 6.5
    vote_count: float = 2000
    popularity: float = 40
    release_year: int = 2024

@app.post("/predict")
async def predict(movie: MovieInput):
    # Prepare data
    data = movie.dict()
    data['log_budget'] = np.log1p(data['budget'])
    data['log_revenue'] = np.log1p(data['revenue'])
    data['profit'] = data['revenue'] - data['budget']
    data['roi'] = data['revenue'] / data['budget'] if data['budget'] > 0 else 1.0
    
    input_df = pd.DataFrame([data])[FEATURES]
    input_scaled = scaler.transform(input_df)
    
    # Predict
    clus = int(kmeans.predict(input_scaled)[0])
    is_quality = bool(classifier.predict(input_scaled)[0])
    prob = classifier.predict_proba(input_scaled)[0][1]
    
    return {
        "cluster": clus,
        "type": LABELS.get(clus, "Unknown"),
        "high_quality_prediction": is_quality,
        "quality_probability": round(prob, 4)
    }

# 6. SERVER EXECUTION
def run_server():
    # Fixed uvicorn call for Python 3.12 / Notebooks
    config = uvicorn.Config(app, host="0.0.0.0", port=8000, log_level="error")
    server = uvicorn.Server(config)
    server.run()

